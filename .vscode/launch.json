{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python: FastAPI (backend)",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": ["main:app", "--host", "127.0.0.1", "--port", "8000"],
      "cwd": "${workspaceFolder}/backend",
      "envFile": "${workspaceFolder}/backend/.env",
      "justMyCode": true
    },
    {
      "name": "PowerShell: restart-backend",
      "type": "PowerShell",
      "request": "launch",
      "script": "${workspaceFolder}/scripts/restart-backend.ps1",
      "cwd": "${workspaceFolder}"
    }
  ]
}

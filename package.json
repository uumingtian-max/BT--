{
  "name": "bklt-blacklight-desktop",
  "productName": "BKLT 黑光",
  "version": "1.2.0",
  "main": "electron/main.js",
  "scripts": {
    "start": "npm run electron",
    "electron": "electron .",
    "app": "npm run build --prefix frontend && electron .",
    "branding": "python scripts/build-branding.py",
    "dev": "concurrently \"npm run frontend-dev\" \"wait-on http://localhost:3000 && set NODE_ENV=development&& electron .\"",
    "frontend-dev": "node scripts/npm.cjs run start --prefix frontend",
    "install:frontend": "node scripts/npm.cjs install --prefix frontend",
    "install:all": "node scripts/npm.cjs install && node scripts/npm.cjs install --prefix frontend"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "electron": "36.4.0",
    "wait-on": "^8.0.3"
  }
}

# BT（黑光）— llama.cpp 多模态 Gemma 4（本机 GGUF）
# 用法：copy backend\.env.local-llamacpp.example backend\.env
# 然后 launcher\START_APP.bat（会自动 ensure-llama-cpp.ps1）
# AI_AGENT_PYTHON=C:\Users\ROG\miniconda3\envs\bt-heiguang\python.exe

LOCK_SINGLE_MODEL=1
LOCKED_MODEL_ID=Gemma4-26B-A4B-Uncensored-HauhauCS-Balanced-Q5_K_P

LLM_BACKEND=openai_compatible
OPENAI_BASE_URL=http://127.0.0.1:8001/v1
OPENAI_API_KEY=local
OLLAMA_TIMEOUT_SEC=180

# llama-server（须支持 --mmproj 的多模态构建）
LLAMA_CPP_EXE=C:\llama-cpp\llama-server.exe
LLAMA_CPP_MODEL=C:\Users\ROG\Documents\Downloads\Gemma4-26B-A4B-Uncensored-HauhauCS-Balanced-Q5_K_P.gguf
LLAMA_CPP_MMPROJ=C:\Users\ROG\Documents\Downloads\mmproj-Gemma4-26B-A4B-Uncensored-HauhauCS-Balanced-f16.gguf
LLAMA_CPP_ALIAS=Gemma4-26B-A4B-Uncensored-HauhauCS-Balanced-Q5_K_P
LLAMA_CPP_CTX_SIZE=4096
LLAMA_CPP_PARALLEL=1
LLAMA_CPP_BATCH_SIZE=512
LLAMA_CPP_UBATCH_SIZE=256
LLAMA_CPP_GPU_LAYERS=auto
LLAMA_CPP_FLASH_ATTN=on
LLAMA_CPP_FIT_TARGET=1536

AGENT_DEFAULT_MODEL=Gemma4-26B-A4B-Uncensored-HauhauCS-Balanced-Q5_K_P
ORCH_PLANNER_MODEL=Gemma4-26B-A4B-Uncensored-HauhauCS-Balanced-Q5_K_P
ORCH_CODER_MODEL=Gemma4-26B-A4B-Uncensored-HauhauCS-Balanced-Q5_K_P
ORCH_REVIEWER_MODEL=Gemma4-26B-A4B-Uncensored-HauhauCS-Balanced-Q5_K_P
ORCH_VISION_MODEL=Gemma4-26B-A4B-Uncensored-HauhauCS-Balanced-Q5_K_P
ORCH_SPEECH_MODEL=Gemma4-26B-A4B-Uncensored-HauhauCS-Balanced-Q5_K_P
AGENT_EVOLVE_MODEL=Gemma4-26B-A4B-Uncensored-HauhauCS-Balanced-Q5_K_P

TASK_DECOMPOSE_BACKEND=openai_compatible
OLLAMA_TASK_MODEL=

AGENT_SKILL_PACK=1
AGENT_SELF_EVOLVE=1
AGENT_EVOLVE_LLM=0

HABIT_CHECK_ENABLED=1
HABIT_CHECK_HOURS=9,21
HABIT_AUTO_SKILL=1

SCHEDULER_ENABLED=1
GATEWAY_ENABLED=1
MCP_BRIDGE_ENABLED=1

OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_NUM_CTX=0

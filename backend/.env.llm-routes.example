# BKLT 黑光三路大模型路由配置
# 复制这段到 backend/.env 或根目录 .env，真实 key 只放本地，不要提交 Git。

LLM_BACKEND=openai_compatible
BKLT_LLM_DEFAULT_ROUTE=gpu
BKLT_LLM_FALLBACK_ORDER=gpu,npu,api
BKLT_LLM_TIMEOUT_SECONDS=60

# GPU 本地模型 API
GPU_OPENAI_BASE_URL=http://127.0.0.1:8001/v1
GPU_OPENAI_API_KEY=local
GPU_MODEL=nvidia/Gemma-4-26B-A4B-NVFP4

# NPU 本地模型 API
NPU_OPENAI_BASE_URL=http://127.0.0.1:8002/v1
NPU_OPENAI_API_KEY=local
NPU_MODEL=your-npu-model-id

# 外部/API 模型：必须同时填 BASE_URL + API_KEY，否则 /meta/models 会 401
API_OPENAI_BASE_URL=https://your-provider.example.com/v1
API_OPENAI_API_KEY=YOUR_API_KEY_HERE
API_MODEL=claude-opus-4-7

# 主聊天若走外部网关（warmup / Agent 默认），也要填 OPENAI_API_KEY
OPENAI_BASE_URL=https://your-provider.example.com/v1
OPENAI_API_KEY=YOUR_API_KEY_HERE
AGENT_DEFAULT_MODEL=claude-opus-4-7
LOCKED_MODEL_ID=claude-opus-4-7

# 本地 GPU 未起时可注释上面两行，改用：
# OPENAI_BASE_URL=http://127.0.0.1:8001/v1
# OPENAI_API_KEY=local
# AGENT_DEFAULT_MODEL=nemotron-omni

# ============================================================
# BKLT 黑光 / BLACKLIGHT  —  后端环境配置示例
# 复制本文件为 backend/.env 并按需修改
# 旧名 ONYX-OVERRIDE 仅作为历史兼容名保留
# ============================================================

# ────────────────────────────────────────────────────────────
# 1. LLM 后端选择
# ────────────────────────────────────────────────────────────

# 当前推荐：OpenAI 兼容接口（本机 vLLM / LiteLLM / LocalAI / NIM / OpenAI）
LLM_BACKEND=openai_compatible
OPENAI_BASE_URL=http://127.0.0.1:8001/v1
OPENAI_API_KEY=local          # 本地 vLLM 可留空或填 "local"

# 兼容路线：Ollama（本地，推荐入门）
# LLM_BACKEND=ollama
# OLLAMA_HOST=http://127.0.0.1:11434

# ────────────────────────────────────────────────────────────
# 2. 默认模型
# ────────────────────────────────────────────────────────────

# 当前 BKLT 黑光推荐模型：须与本机 OpenAI-compatible 网关 /v1/models 输出一致
AGENT_DEFAULT_MODEL=nvidia/Gemma-4-26B-A4B-NVFP4

# Ollama 路线示例：须与 `ollama list` 输出一致
# AGENT_DEFAULT_MODEL=qwen3:14b

# ────────────────────────────────────────────────────────────
# 3. 服务端口
# ────────────────────────────────────────────────────────────

BACKEND_PORT=8000          # FastAPI 监听端口
BACKEND_HOST=0.0.0.0       # 0.0.0.0 = 局域网可访问；127.0.0.1 = 仅本机

# ────────────────────────────────────────────────────────────
# 4. 习惯体检（Habit Check）
# ────────────────────────────────────────────────────────────

HABIT_CHECK_ENABLED=true
HABIT_CHECK_HOURS=9,21          # 每天执行时刻（本地时间，逗号分隔）
HABIT_AUTO_SKILL=true           # 行为变化时自动更新 learned_habit_auto.md
HABIT_REPORT_DIR=outputs/habit_checks

# ────────────────────────────────────────────────────────────
# 5. Agent / 工具配置
# ────────────────────────────────────────────────────────────

AGENT_MAX_STEPS=20              # Agent 单次最多工具调用步数
AGENT_TIMEOUT_SECONDS=120       # 单步超时（秒）
AGENT_BROWSER_ENABLED=true      # 是否启用浏览器工具
AGENT_FILE_ROOT=.               # 文件读写沙盒根目录（相对于 backend/）

# ────────────────────────────────────────────────────────────
# 6. TTS（F5-TTS，可选）
# ────────────────────────────────────────────────────────────

TTS_ENABLED=false
TTS_HOST=http://127.0.0.1:7860  # F5-TTS Gradio 接口地址
TTS_VOICE=default               # 声音 ID / 参考音频标签

# ────────────────────────────────────────────────────────────
# 7. 移动 / 远程访问（Tailscale / ngrok）
# ────────────────────────────────────────────────────────────

# 启用后前端可通过局域网 IP 或 Tailscale IP 访问
REMOTE_ACCESS_ENABLED=false
# TAILSCALE_IP=100.x.x.x
# MOBILE_ACCESS_TOKEN=change_me_for_remote_access

# ────────────────────────────────────────────────────────────
# 8. 日志
# ────────────────────────────────────────────────────────────

LOG_LEVEL=INFO           # DEBUG / INFO / WARNING / ERROR
LOG_FILE=logs/backend.log
LOG_ROTATION=7           # 保留天数

# ────────────────────────────────────────────────────────────
# 9. CORS（跨域，开发用）
# ────────────────────────────────────────────────────────────

# 生产环境建议改为具体域名/IP，避免使用 *
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ────────────────────────────────────────────────────────────
# 10. Cline / VS Code 集成（可选）
# ────────────────────────────────────────────────────────────

# CLINE_OLLAMA_BASE_URL=http://127.0.0.1:11434
# CLINE_OLLAMA_MODEL=qwen3:14b

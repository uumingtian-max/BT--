# ============================================================
# BKLT 黑光 / BLACKLIGHT  —  后端环境配置示例
# 复制本文件为 backend/.env 并按需修改
# 旧名 ONYX-OVERRIDE 仅作为历史兼容名保留
# ============================================================

# ────────────────────────────────────────────────────────────
# 1. LLM 后端选择（二选一，取消注释对应那组）
# ────────────────────────────────────────────────────────────

# ── 路线 A：Ollama（本机多模型栈，推荐日常）─────────────────
LLM_BACKEND=ollama
OLLAMA_HOST=http://127.0.0.1:11434

# ── 路线 B：OpenAI 兼容接口（vLLM / LiteLLM / NIM / OpenAI）─
# 使用路线 B 时，注释掉路线 A，取消下面三行注释
# LLM_BACKEND=openai_compatible
# OPENAI_BASE_URL=http://127.0.0.1:8001/v1   # 本机 vLLM；换 OpenAI 改为 https://api.openai.com/v1
# OPENAI_API_KEY=local                        # 本地填 "local"；OpenAI 填 sk-xxx

# ────────────────────────────────────────────────────────────
# 2. 默认模型（随路线不同而不同，对应修改）
# ────────────────────────────────────────────────────────────

# 路线 A（Ollama）主聊天模型 → 须与 `ollama list` 输出一致
AGENT_DEFAULT_MODEL=qwen3.5:9b

# 路线 B（vLLM / Gemma4）主模型 → 须与网关 /v1/models 输出一致
# AGENT_DEFAULT_MODEL=nvidia/Gemma-4-26B-A4B-NVFP4

# ────────────────────────────────────────────────────────────
# 3. 服务端口
# ────────────────────────────────────────────────────────────

BACKEND_PORT=8000          # FastAPI 监听端口
BACKEND_HOST=127.0.0.1     # 127.0.0.1 = 仅本机；0.0.0.0 = 局域网（须配 MOBILE_ACCESS_TOKEN）

# 监听 0.0.0.0 时是否强制远程/LAN 鉴权（无 token 则拒绝非本机请求）
REQUIRE_API_TOKEN_ON_LAN=1

# ────────────────────────────────────────────────────────────
# 4. 习惯体检（Habit Check）
# ────────────────────────────────────────────────────────────

HABIT_CHECK_ENABLED=true
HABIT_CHECK_HOURS=9,21          # 每天执行时刻（本地时间，逗号分隔）
HABIT_AUTO_SKILL=true           # 行为变化时自动更新 learned_habit_auto.md
HABIT_REPORT_DIR=outputs/habit_checks

# ────────────────────────────────────────────────────────────
# 5. Agent / 工具配置
# ────────────────────────────────────────────────────────────

AGENT_MAX_STEPS=20              # Agent 单次最多工具调用步数
AGENT_TIMEOUT_SECONDS=120       # 单步超时（秒）
AGENT_BROWSER_ENABLED=true      # 是否启用浏览器工具
AGENT_FILE_ROOT=.               # 文件读写沙盒根目录（相对于 backend/）
AGENT_TOOL_AUTO_CONFIRM=0       # 默认 0：confirm/dangerous 须前端确认；本机独享开发可改 1
AGENT_NAME=BT（黑光）             # 聊天/Agent 自称（勿用泛用客服名）
AGENT_USER_NAME=权哥              # 对你的称呼
# 可选 GPU 依赖: pip install nvidia-ml-py ；显存清理需 torch+CUDA

# ── 生产 / 对外分享（LAN、演示机、给他人试用）────────────────
# 建议复制本段到 backend/.env，与「本机独享开发」区分：
#
#   AGENT_TOOL_AUTO_CONFIRM=0
#   REQUIRE_API_TOKEN_ON_LAN=1
#   MOBILE_ACCESS_TOKEN=<随机长串>
#   BACKEND_HOST=0.0.0.0          # 仅在你明确需要局域网访问时
#
# 效果：
# - run_shell、write_file、kill_process 等 confirm/dangerous 工具不会静默执行；
#   Agent 会返回 tool_confirm_required，前端需用户点确认（parameters.confirmed=true）。
# - 不要把 backend/.env、chat.db、memory.db 打进 zip 或上传到网盘。
# - 本机独享开发可在 backend/.env 设 AGENT_TOOL_AUTO_CONFIRM=1（勿提交到共享环境）。

# 多模型智能路由（见 model_router.MODEL_ROLE_CATALOG）
SMART_ROUTER_ENABLED=1
FAST_MODEL=qwen3.5:9b
AGENT_ROUTER_MODEL=functiongemma:latest
EMBED_MODEL=nomic-embed-text:latest
REASONING_MODEL=deepseek-r1:7b
CODE_MODEL=deepseek-coder-v2:16b
CODE_SIMPLE_MODEL=qwen3.5:9b
TASK_MODEL=qwen3.5:9b
ORCH_PLANNER_MODEL=deepseek-r1:7b
ORCH_CODER_MODEL=deepseek-coder-v2:16b
ORCH_REVIEWER_MODEL=qwen3.5:9b
ORCH_VISION_MODEL=qwen3.5:9b
ORCH_SPEECH_MODEL=qwen3.5:9b
AGENT_EVOLVE_MODEL=deepseek-r1:7b

# Ollama 常驻 / 按需（5090 24G 推荐四常驻 + coder 按需）
OLLAMA_KEEP_ALIVE=24h
OLLAMA_WARM_ON_STARTUP=1
OLLAMA_RESIDENT_MODELS=nomic-embed-text:latest,functiongemma:latest,qwen3.5:9b,deepseek-r1:7b
OLLAMA_ON_DEMAND_MODELS=deepseek-coder-v2:16b
OLLAMA_RELEASE_ON_DEMAND=1
OLLAMA_NUM_CTX=4096

# ────────────────────────────────────────────────────────────
# 6. TTS（F5-TTS，可选）
# ────────────────────────────────────────────────────────────
# 安装：launcher\INSTALL_F5_TTS.bat
# 启动：python -m uvicorn backend.f5_tts_server:app --host 127.0.0.1 --port 9880
# 主后端通过 REAL_TTS_URL 调用，torch/F5-TTS 只在子进程加载，不影响主进程启动速度

TTS_ENABLED=false
TTS_HOST=http://127.0.0.1:7860   # Gradio 接口（旧兼容）
REAL_TTS_URL=http://127.0.0.1:9880  # f5_tts_server 接口（新，优先）

# 参考音频（3-10 秒，须有授权，用于声纹克隆）
F5_TTS_REF_AUDIO=                   # 例：assets/voice/ref.wav
F5_TTS_REF_TEXT=                    # 与 ref.wav 对应的原文（提高对齐精度）

# 模型选项（默认自动下载，通常不需要改）
F5_TTS_MODEL=F5TTS_v1_Base          # 或 E2TTS_Base
# F5_TTS_CKPT_FILE=                 # 自定义 checkpoint 路径（留空=自动）
# F5_TTS_VOCAB_FILE=                # 自定义词表路径（留空=自动）
# F5_TTS_HF_ENDPOINT=               # 国内镜像：https://hf-mirror.com

# 生成参数
F5_TTS_MAX_CHARS=450                # 单次最大字符数
F5_TTS_SPEED=                       # 留空=自动；范围 0.5-2.0
F5_TTS_NFE_STEP=24                  # ODE 步数，越大越慢越准
F5_TTS_REMOVE_SILENCE=1             # 1=去除首尾静音
# F5_TTS_DEVICE=                    # 留空=自动；可填 cpu / cuda / mps

# ────────────────────────────────────────────────────────────
# 7. 移动 / 远程访问（Tailscale / ngrok）
# ────────────────────────────────────────────────────────────

# 启用后前端可通过局域网 IP 或 Tailscale IP 访问
REMOTE_ACCESS_ENABLED=false
# TAILSCALE_IP=100.x.x.x
# MOBILE_ACCESS_TOKEN=change_me_for_remote_access

# ────────────────────────────────────────────────────────────
# 8. 日志
# ────────────────────────────────────────────────────────────

LOG_LEVEL=INFO           # DEBUG / INFO / WARNING / ERROR
LOG_FILE=logs/backend.log
LOG_ROTATION=7           # 保留天数

# ────────────────────────────────────────────────────────────
# 9. CORS（跨域，开发用）
# ────────────────────────────────────────────────────────────

# 生产环境建议改为具体域名/IP，避免使用 *
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ────────────────────────────────────────────────────────────
# 10. Cline / VS Code 集成（可选）
# ────────────────────────────────────────────────────────────

# CLINE_OLLAMA_BASE_URL=http://127.0.0.1:11434
# CLINE_OLLAMA_MODEL=qwen3.5:9b

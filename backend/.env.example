# ============================================================
# BKLT 黑光 / BT — 后端环境配置示例
# 复制为 backend/.env 后只保留「一条」LLM 路线（Ollama 或 OpenAI 兼容），勿混用重复键
# ============================================================

AI_AGENT_PYTHON=C:\Users\ROG\miniconda3\envs\bt-heiguang\python.exe

AGENT_USER_NAME=权哥
AGENT_NAME=小涵

# ────────────────────────────────────────────────────────────
# 1. LLM 后端（二选一，取消注释其中一组）
# ────────────────────────────────────────────────────────────

# 【推荐】本机 Ollama（5090 24G 精简 5 模型栈，见下方第 5 节）
LLM_BACKEND=ollama
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_TIMEOUT_SEC=180
OLLAMA_NUM_CTX=0
OPENAI_BASE_URL=
OPENAI_API_KEY=local

# 【可选】OpenAI 兼容网关（vLLM / llama.cpp / LM Studio）
# LLM_BACKEND=openai_compatible
# OPENAI_BASE_URL=http://127.0.0.1:8001/v1
# OPENAI_API_KEY=local
# VLLM_DEFAULT_MODEL=nvidia/Gemma-4-26B-A4B-NVFP4

# ────────────────────────────────────────────────────────────
# 2. 服务端口
# ────────────────────────────────────────────────────────────

BACKEND_PORT=8000
BACKEND_HOST=127.0.0.1
REQUIRE_API_TOKEN_ON_LAN=1

# ────────────────────────────────────────────────────────────
# 3. 习惯体检
# ────────────────────────────────────────────────────────────

HABIT_CHECK_ENABLED=true
HABIT_CHECK_HOURS=9,21
HABIT_AUTO_SKILL=true
HABIT_REPORT_DIR=outputs/habit_checks

# ────────────────────────────────────────────────────────────
# 4. Agent / 工具
# ────────────────────────────────────────────────────────────

AGENT_MAX_STEPS=20
AGENT_TIMEOUT_SECONDS=120
COMPRESS_FAIL_MODE=truncate
AGENT_BROWSER_ENABLED=true
AGENT_FILE_ROOT=.
AGENT_TOOL_AUTO_CONFIRM=1

AGENT_POLICY_ENABLED=1
AGENT_POLICY_BLOCK_SENSITIVE=1
AGENT_POLICY_STRICT=0
# AGENT_POLICY_SAFE_PATHS=C:\Users\ROG\Desktop\ai-agent-project;C:\Users\ROG\Desktop

MEMORY_VECTOR_ENABLED=1
MEMORY_EMBED_MODEL=nomic-embed-text:latest

AGENT_SKILL_PACK=1
AGENT_SELF_EVOLVE=1
AGENT_EVOLVE_LLM=1

SCHEDULER_ENABLED=1
GATEWAY_ENABLED=1
MCP_BRIDGE_ENABLED=1

LOCK_SINGLE_MODEL=0
LOCKED_MODEL_ID=qwen3.5:4b
SMART_ROUTER_ENABLED=1

# ────────────────────────────────────────────────────────────
# 5. Ollama 五模型岗位（视觉/答案/推理/写码/嵌入/路由）
#    画图走 generate_image（Stable Diffusion），不是 Ollama
#    已裁重叠：qwen3.5:0.8b、nemotron-3-nano:4b、granite4:3b
# ────────────────────────────────────────────────────────────

OLLAMA_KEEP_ALIVE=24h
OLLAMA_WARM_ON_STARTUP=1
STRICT_MODEL_ROLES=1

# 常驻约 9.7G：embed + router + qwen3.5:4b + r1（启动预热，不预热 coder）
OLLAMA_RESIDENT_MODELS=nomic-embed-text:latest,functiongemma:latest,qwen3.5:4b,deepseek-r1:7b
OLLAMA_ON_DEMAND_MODELS=deepseek-coder-v2:16b
OLLAMA_RELEASE_ON_DEMAND=1
OLLAMA_ON_DEMAND_KEEP_ALIVE=10m

AGENT_DEFAULT_MODEL=qwen3.5:4b
FAST_MODEL=qwen3.5:4b
AGENT_ROUTER_MODEL=functiongemma:latest
EMBED_MODEL=nomic-embed-text:latest
REASONING_MODEL=deepseek-r1:7b
CODE_MODEL=deepseek-coder-v2:16b
CODE_SIMPLE_MODEL=qwen3.5:4b
TASK_MODEL=qwen3.5:4b

ORCH_PLANNER_MODEL=deepseek-r1:7b
ORCH_CODER_MODEL=deepseek-coder-v2:16b
ORCH_REVIEWER_MODEL=qwen3.5:4b
ORCH_VISION_MODEL=qwen3.5:4b
ORCH_SPEECH_MODEL=qwen3.5:4b
AGENT_EVOLVE_MODEL=deepseek-r1:7b
OLLAMA_TASK_MODEL=qwen3.5:4b
TASK_DECOMPOSE_BACKEND=ollama

ORCH_PLANNER_MODELS=
ORCH_CODER_MODELS=
ORCH_REVIEWER_MODELS=
ORCH_REASONING_MODELS=
ORCH_VISION_MODELS=
ORCH_SPEECH_MODELS=

# ────────────────────────────────────────────────────────────
# 6. 本地画图（Stable Diffusion，可选）
# ────────────────────────────────────────────────────────────

# ENABLE_LOCAL_SD=1
# pip install -r backend/requirements.txt -r backend/requirements-media.txt

# ────────────────────────────────────────────────────────────
# 7. F5-TTS 语音（可选，独立进程，见 launcher/INSTALL_F5_TTS.bat）
# ────────────────────────────────────────────────────────────

TTS_ENABLED=false
TTS_HOST=http://127.0.0.1:7860
TTS_VOICE=default
REAL_TTS_URL=http://127.0.0.1:7860/tts

F5_TTS_REF_AUDIO=
F5_TTS_REF_TEXT=
F5_TTS_MODEL=F5TTS_v1_Base
F5_TTS_DEVICE=
F5_TTS_MAX_CHARS=450
F5_TTS_SPEED=
F5_TTS_NFE_STEP=24
F5_TTS_REMOVE_SILENCE=1
F5_TTS_CKPT_FILE=
F5_TTS_VOCAB_FILE=
F5_TTS_HF_ENDPOINT=

# pip install -r backend/requirements-tts.txt  # 可选，体积大

# ────────────────────────────────────────────────────────────
# 8. 远程 / 日志 / CORS
# ────────────────────────────────────────────────────────────

REMOTE_ACCESS_ENABLED=false
LOG_LEVEL=INFO
LOG_FILE=logs/backend.log
LOG_ROTATION=7
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# CLINE_OLLAMA_BASE_URL=http://127.0.0.1:11434
# CLINE_OLLAMA_MODEL=qwen3.5:4b

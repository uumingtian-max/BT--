# BT（黑光）— vLLM + Nano-Omni-30B（主 Agent）
# copy backend\.env.local-vllm-nano.example backend\.env
# 启动: powershell -File scripts\use-vllm.ps1

LLM_GATEWAY=vllm
VLLM_ENABLED=1
LLM_BACKEND=openai_compatible
OPENAI_BASE_URL=http://127.0.0.1:8001/v1
OPENAI_API_KEY=local
OLLAMA_TIMEOUT_SEC=300

LOCAL_MODEL_DIR=D:\models\Nemotron-3-Nano-Omni-30B-A3B-Reasoning-NVFP4
VLLM_WSL_MODEL_DIR=/mnt/d/models/Nemotron-3-Nano-Omni-30B-A3B-Reasoning-NVFP4
VLLM_USE_WSL=1

LOCK_SINGLE_MODEL=1
LOCKED_MODEL_ID=/mnt/d/models/Nemotron-3-Nano-Omni-30B-A3B-Reasoning-NVFP4
AGENT_DEFAULT_MODEL=/mnt/d/models/Nemotron-3-Nano-Omni-30B-A3B-Reasoning-NVFP4
ORCH_PLANNER_MODEL=/mnt/d/models/Nemotron-3-Nano-Omni-30B-A3B-Reasoning-NVFP4
ORCH_CODER_MODEL=/mnt/d/models/Nemotron-3-Nano-Omni-30B-A3B-Reasoning-NVFP4
ORCH_REVIEWER_MODEL=/mnt/d/models/Nemotron-3-Nano-Omni-30B-A3B-Reasoning-NVFP4
ORCH_VISION_MODEL=/mnt/d/models/Nemotron-3-Nano-Omni-30B-A3B-Reasoning-NVFP4
ORCH_SPEECH_MODEL=/mnt/d/models/Nemotron-3-Nano-Omni-30B-A3B-Reasoning-NVFP4
AGENT_EVOLVE_MODEL=/mnt/d/models/Nemotron-3-Nano-Omni-30B-A3B-Reasoning-NVFP4
EXTRA_MODEL_IDS=/mnt/d/models/Nemotron-3-Nano-Omni-30B-A3B-Reasoning-NVFP4

# 小模型 Intel NPU（embed）；rerank-vl 见 docs/intel-npu-small-models.md
EMBED_BACKEND=openvino
EMBED_OV_DEVICE=NPU
EMBED_LOCAL_DIR=D:\models\llama-nemotron-embed-1b-v2
EMBED_OV_DIR=D:\models\llama-nemotron-embed-1b-v2-ov-int8
EMBED_OV_NPU_DIR=D:\models\llama-nemotron-embed-1b-v2-ov-npu
EMBED_MODEL=llama-nemotron-embed-1b-v2
SKILL_EMBED_MODEL=llama-nemotron-embed-1b-v2
OLLAMA_HOST=http://127.0.0.1:11434
SMART_ROUTER_ENABLED=0

# Marvis 风格：efficiency=可联网搜索；privacy=本地优先禁 web_search
AGENT_RUNTIME_MODE=privacy
# AGENT_PRIVACY_ALLOW_WEB=0

# Rerank（记忆/知识库召回后二次排序；无 NPU IR 时用 embed 余弦）
RERANK_ENABLED=1
RERANK_LOCAL_DIR=D:\models\llama-nemotron-rerank-1b-v2
RERANK_OV_NPU_DIR=D:\models\llama-nemotron-rerank-1b-v2-ov-npu
RERANK_OV_DEVICE=NPU

# 世界级执行纪律：计划可见 + 工具瞬态重试 + 证据优先回答
AGENT_TIER=world
AGENT_WORLD_CLASS=1
AGENT_TOOL_RETRY_MAX=2
AGENT_TASK_PLAN=1

AGENT_TOOL_AUTO_CONFIRM=0
AGENT_POLICY_ENABLED=1
AGENT_SKILL_PACK=1
# Omni 多模态：理解图/视频/音频（vLLM 需 scripts/start-omni-vllm-wsl.sh）；文生视频用 generate_video 工具
# AGENT_OMNI_MM_ENABLED=1
HABIT_CHECK_ENABLED=1
SCHEDULER_ENABLED=1
GATEWAY_ENABLED=1
MCP_BRIDGE_ENABLED=1

BACKEND_PORT=8000
BACKEND_HOST=127.0.0.1

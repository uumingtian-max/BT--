# ============================================================
# 双引擎同时用：inferaichat(Opus) + 本地 GPU(Nemotron Omni)
# 复制到 backend/.env 中对应段落（勿提交真实 sk-）
# ============================================================

LLM_BACKEND=openai_compatible
BKLT_DUAL_ENGINE=1
BKLT_LLM_DEFAULT_ROUTE=api
BKLT_LLM_FALLBACK_ORDER=api,gpu

# ── API 云：纯文字 / Agent 默认 ──
API_OPENAI_BASE_URL=https://inferaichat.com/v1
API_OPENAI_API_KEY=YOUR_API_KEY_HERE
API_MODEL=claude-opus-4-7

OPENAI_BASE_URL=https://inferaichat.com/v1
OPENAI_API_KEY=YOUR_API_KEY_HERE
AGENT_DEFAULT_MODEL=claude-opus-4-7
LOCKED_MODEL_ID=claude-opus-4-7

# ── GPU 本地：附件 / 图 / 音视频（SGLang OpenAI 兼容，不是 Ollama）──
# 本机 sglang.launch_server 默认 :30000；Docker compose 映射为 :8001
GPU_OPENAI_BASE_URL=http://127.0.0.1:30000/v1
SGLANG_BASE_URL=http://127.0.0.1:30000/v1
GPU_OPENAI_API_KEY=local
GPU_MODEL=nemotron-omni
BKLT_OMNI_MODEL=nemotron-omni
ORCH_VISION_MODEL=nemotron-omni
ORCH_SPEECH_MODEL=nemotron-omni

AGENT_OMNI_MM_ENABLED=1

# 编排子任务仍可用 Opus
ORCH_PLANNER_MODEL=claude-opus-4-7
ORCH_CODER_MODEL=claude-opus-4-7
ORCH_REVIEWER_MODEL=claude-opus-4-7

# ── inferaichat 有 IP 白名单时（三选一）──
# 1) 在 inferaichat 控制台把你当前公网 IP 加入白名单（家用宽带会变，需经常改）
# 2) 固定出口 VPS 代理（推荐）：
# BKLT_API_HTTP_PROXY=http://用户:密码@你的VPS公网IP:端口
# 3) 暂时不用云端，纯本地：
# BKLT_LLM_DEFAULT_ROUTE=gpu
# AGENT_DEFAULT_MODEL=nemotron-omni

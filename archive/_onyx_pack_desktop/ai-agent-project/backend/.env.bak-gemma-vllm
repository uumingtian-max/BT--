# ONYX 本机推理：Gemma 4 26B A4B NVFP4 + vLLM（RTX 5090 24GB 推荐）
# 权重目录: D:\models\Gemma-4-26B-A4B-NVFP4
# 1) 放入两个分片: scripts\install-gemma-weights.ps1
# 2) copy backend\.env.local-gemma4.example backend\.env
# 3) scripts\START_VLLM_GEMMA4.bat  然后  START_APP_LOCAL.bat

LOCAL_MODEL_DIR=D:\models\Gemma-4-26B-A4B-NVFP4

LLM_BACKEND=openai_compatible
OPENAI_BASE_URL=http://127.0.0.1:8001/v1
OPENAI_API_KEY=local
OLLAMA_TIMEOUT_SEC=180

AGENT_DEFAULT_MODEL=nvidia/Gemma-4-26B-A4B-NVFP4
ORCH_PLANNER_MODEL=nvidia/Gemma-4-26B-A4B-NVFP4
ORCH_CODER_MODEL=nvidia/Gemma-4-26B-A4B-NVFP4
ORCH_REVIEWER_MODEL=nvidia/Gemma-4-26B-A4B-NVFP4
ORCH_VISION_MODEL=nvidia/Gemma-4-26B-A4B-NVFP4
ORCH_SPEECH_MODEL=nvidia/Gemma-4-26B-A4B-NVFP4
AGENT_EVOLVE_MODEL=nvidia/Gemma-4-26B-A4B-NVFP4

TASK_DECOMPOSE_BACKEND=openai_compatible
OLLAMA_TASK_MODEL=

AGENT_SKILL_PACK=1
AGENT_SELF_EVOLVE=1
AGENT_EVOLVE_LLM=0

HABIT_CHECK_ENABLED=1
HABIT_CHECK_HOURS=9,21
HABIT_AUTO_SKILL=1

SCHEDULER_ENABLED=1
GATEWAY_ENABLED=1
MCP_BRIDGE_ENABLED=1

# 不用 Ollama 时可忽略
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_NUM_CTX=0

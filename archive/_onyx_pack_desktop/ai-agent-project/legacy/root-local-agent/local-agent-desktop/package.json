{
  "name": "local-agent-desktop",
  "version": "1.0.0",
  "private": true,
  "main": "main.cjs",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.local.agent",
    "productName": "LocalAgent",
    "directories": { "output": "dist" },
    "win": { "target": ["nsis"] },
    "mac": { "target": ["dmg"] },
    "files": ["main.cjs", "preload.cjs"]
  }
}

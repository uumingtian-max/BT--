{
  "name": "onyx-override-desktop",
  "productName": "ONYX-OVERRIDE",
  "version": "1.1.0",
  "main": "electron/main.js",
  "scripts": {
    "electron": "electron .",
    "app": "node scripts/npm.cjs run build --prefix frontend && electron .",
    "branding": "python scripts/build-branding.py",
    "dev": "concurrently \"npm run frontend-dev\" \"wait-on http://localhost:3000 && electron .\"",
    "frontend-dev": "node scripts/npm.cjs run start --prefix frontend",
    "install:frontend": "node scripts/npm.cjs install --prefix frontend",
    "install:all": "node scripts/npm.cjs install && node scripts/npm.cjs install --prefix frontend"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "electron": "^42.1.0",
    "wait-on": "^8.0.3"
  }
}

# ONYX：Gemma 4 + OpenAI 兼容网关（vLLM 等）— 实验性配置
#
# 【稳】Windows 日常：用 Ollama 直连 GPU，复制 backend\.env.example -> .env，
#     安装 Ollama 后 ollama pull 你的模型，LLM_BACKEND=ollama。勿在 Windows 上 pip 装 vLLM。
# 【险】本文件：需本机已有可用的 /v1 网关（多为 Linux 服务器或 WSL+CUDA 自管 vLLM）。
#     原生 Windows 上 vLLM 无法稳定用 GPU；若网关未起来，模型不会在 GPU 上跑。
#
# 权重目录: D:\models\Gemma-4-26B-A4B-NVFP4
# 1) 放入两个分片: scripts\install-gemma-weights.ps1
# 2) copy backend\.env.local-gemma4.example backend\.env
# 3) 仅在网关已就绪时：START_APP_LOCAL.bat（或先 scripts\START_VLLM_GEMMA4.bat 实验性启动 WSL vLLM）
#
# 【重要】下列 *_MODEL / LOCKED_MODEL_ID 必须与网关 GET /v1/models 返回的 id 完全一致。
# vLLM 若用本地目录启动，id 常为路径形式，例如：/mnt/d/models/Gemma-4-26B-A4B-NVFP4
# NIM / 部分云端则为：nvidia/Gemma-4-26B-A4B-NVFP4 — 以你本机 API 为准。

LOCAL_MODEL_DIR=D:\models\Gemma-4-26B-A4B-NVFP4

LOCK_SINGLE_MODEL=1
LOCKED_MODEL_ID=/mnt/d/models/Gemma-4-26B-A4B-NVFP4

LLM_BACKEND=openai_compatible
OPENAI_BASE_URL=http://127.0.0.1:8001/v1
OPENAI_API_KEY=local
OLLAMA_TIMEOUT_SEC=180

AGENT_DEFAULT_MODEL=/mnt/d/models/Gemma-4-26B-A4B-NVFP4
ORCH_PLANNER_MODEL=/mnt/d/models/Gemma-4-26B-A4B-NVFP4
ORCH_CODER_MODEL=/mnt/d/models/Gemma-4-26B-A4B-NVFP4
ORCH_REVIEWER_MODEL=/mnt/d/models/Gemma-4-26B-A4B-NVFP4
ORCH_VISION_MODEL=/mnt/d/models/Gemma-4-26B-A4B-NVFP4
ORCH_SPEECH_MODEL=/mnt/d/models/Gemma-4-26B-A4B-NVFP4
AGENT_EVOLVE_MODEL=/mnt/d/models/Gemma-4-26B-A4B-NVFP4

TASK_DECOMPOSE_BACKEND=openai_compatible
OLLAMA_TASK_MODEL=

AGENT_SKILL_PACK=1
AGENT_SELF_EVOLVE=1
AGENT_EVOLVE_LLM=0

HABIT_CHECK_ENABLED=1
HABIT_CHECK_HOURS=9,21
HABIT_AUTO_SKILL=1

SCHEDULER_ENABLED=1
GATEWAY_ENABLED=1
MCP_BRIDGE_ENABLED=1

WEBHOOK_URL=
EXTRA_MODEL_IDS=/mnt/d/models/Gemma-4-26B-A4B-NVFP4
REQUEST_LOG=

PLAYWRIGHT_BROWSERS_PATH=%LOCALAPPDATA%\ms-playwright
ENABLE_IMAGE_PLACEHOLDER=1

# 不用 Ollama 时可忽略
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_NUM_CTX=0

# Windows 本机推荐：LLM_BACKEND=ollama（Ollama 直连 GPU，最稳）。下面「Gemma+vLLM」在 Windows 上
# 多为实验路径，需自备 Linux/WSL GPU 网关；勿在 Windows 上 `pip install vllm` 指望能用 GPU。
# 若走实验路径：复制 backend\.env.local-gemma4.example -> .env，_gateway_ 就绪后再 START_APP_LOCAL.bat
#
# ── 可选：Linux 或稳定兼容网关上的 Gemma + vLLM 示例（非 Windows 日常）──

# Ollama（可选；用本机 vLLM 时不必启动）
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_TIMEOUT_SEC=120
OLLAMA_NUM_CTX=0

# LLM transport: ollama | openai_compatible（vLLM / 商户 API，须 OPENAI_BASE_URL 以 /v1 结尾）
LLM_BACKEND=ollama
OPENAI_BASE_URL=
OPENAI_API_KEY=

# 可选：NVIDIA Build / Integrate 云端（OpenAI 兼容，密钥用 nvapi-…，仅填本机 .env，勿提交）
# LLM_BACKEND=openai_compatible
# OPENAI_BASE_URL=https://integrate.api.nvidia.com/v1
# OPENAI_API_KEY=nvapi-从 build.nvidia.com 获取
# AGENT_DEFAULT_MODEL=与面板一致的 id，例如 meta/llama-4-maverick-17b-128e-instruct
# 连通性自检：NVIDIA_API_KEY=... node scripts/nvidia-integrate-chat-example.mjs
# 或：NVIDIA_API_KEY=... python scripts/nvidia_integrate_chat_example.py

# 可选：本机 9router（OpenAI 兼容，默认端口 20128）。先在 9router 面板连接提供商并复制 API Key。
# LLM_BACKEND=openai_compatible
# OPENAI_BASE_URL=http://127.0.0.1:20128/v1
# OPENAI_API_KEY=从 http://localhost:20128/dashboard 复制
# AGENT_DEFAULT_MODEL=面板里列出的模型 id（勿填本地 Ollama 名，除非 9router 已路由该名）

# 可选：关闭 Telegraf 指标路由（仍保留 /health）。默认开启。
# TELEGRAF_METRICS=0

# Default chat + agent model (when request body omits model)
AGENT_DEFAULT_MODEL=qwen3:14b

# /chat 系统提示里的用户称呼与助手名（可选；不设则用内置默认中文名）
# AGENT_USER_NAME=
# AGENT_NAME=

# 多模型编排（仅使用白名单三模型中的 id）
ORCH_PLANNER_MODEL=yanjia/Qwen3.6-35B-A3B-Opus4.7-Reasoning-Distilled:q4km
ORCH_CODER_MODEL=qwen3:14b
ORCH_REVIEWER_MODEL=qwen3:14b
ORCH_VISION_MODEL=qwen3:14b
ORCH_SPEECH_MODEL=qwen3:14b

# Context packing (OpenHuman-style: shrink before LLM)
AGENT_TOOL_RESULT_MAX_CHARS=12000
AGENT_CONTEXT_MAX_CHARS=6000
AGENT_MAX_STEPS=6
CHAT_HISTORY_MAX_MESSAGES=40

# 自进化与技能包（默认全开；蒸馏需显式打开 AGENT_EVOLVE_LLM）
AGENT_SKILL_PACK=1
AGENT_SELF_EVOLVE=1
AGENT_EVOLVE_LLM=0
AGENT_EVOLVE_MODEL=

# ── Legacy POST /agent 任务分解（local_agent_api：与主 /chat 编排无关）──
# body.use_llm=false：仅用分隔符规则拆分，不看本变量。
# body.use_llm=true：
#   - TASK_DECOMPOSE_BACKEND=ollama | local | openhuman | openai | openai_compatible | vllm | litellm | localai
#     → 走 chat_complete_sync（与 LLM_BACKEND / OPENAI_BASE_URL 一致）做 LLM 分解。
#   - 其它值（含 hf、空字符串、任意未列出的名字）→ 走本机 Transformers（_decompose_tasks，需已装 torch/transformers）。
# 默认未设置时按代码内默认 ollama；若显式设为空字符串则走 HF 路径。
TASK_DECOMPOSE_BACKEND=ollama
OLLAMA_TASK_MODEL=

# Legacy local agent root (optional)
# LOCAL_AGENT_ROOT=

# Integrations
# 任务完成后 POST JSON（可与 n8n / 自建总线对接）；未配置时 /meta/doctor 视为可选通过
WEBHOOK_URL=
# WEBHOOK_REQUIRED=1
# 逗号分隔：与前端「模型」三项白名单一致（无空格）；含 Gemma4 便于网关或 Modelfile 名称对齐
EXTRA_MODEL_IDS=nvidia/Gemma-4-26B-A4B-NVFP4,yanjia/Qwen3.6-35B-A3B-Opus4.7-Reasoning-Distilled:q4km,qwen3:14b
# 访问日志：1 / true / on
REQUEST_LOG=

# ── 习惯体检（每天两次本机检测 → 行为分析 → 自我扩展）──
HABIT_CHECK_ENABLED=1
# 本地时区小时，逗号分隔，默认早 9 点 / 晚 9 点
HABIT_CHECK_HOURS=9,21
# 行为变化时自动更新 agent_skills/learned_habit_auto.md
HABIT_AUTO_SKILL=1
# 每次体检后尝试 LLM 蒸馏 playbook（需 AGENT_EVOLVE_LLM=1）
HABIT_EVOLVE_ON_CHECK=0
# HABIT_WEBHOOK_URL=

# ── 扩展模块（Hermes 风格单独立项，默认开启）──
SCHEDULER_ENABLED=1
SCHEDULER_TICK_SEC=30
# SCHEDULER_WEBHOOK_URL=

GATEWAY_ENABLED=1
# GATEWAY_SECRET=设则 inbound 须带 ?token=
# GATEWAY_CHANNELS=telegram,discord,slack,generic
# GATEWAY_REPLY_WEBHOOK=

MCP_BRIDGE_ENABLED=1
# MCP_SERVERS=[{"name":"remote","url":"http://127.0.0.1:9000","tools":["custom_tool"]}]

# 行为采样 observe：桌面「近期文件」仅浅扫两层。默认黑名单过滤 .lnk/.tmp/~$ 等；
# 若仍嫌噪声或要省 token，可设白名单（逗号分隔、不含点），仅保留列出的扩展名（仍先过黑名单）。
# OBSERVE_DESKTOP_RECENT_EXTS=py,md,txt,json,yml,yaml,toml,csv,ts,tsx,js,jsx

# 浏览器工具: pip install -r requirements-extras.txt && playwright install chromium
PLAYWRIGHT_BROWSERS_PATH=%LOCALAPPDATA%\ms-playwright

# 出图：默认无 SD 时生成 PNG 占位图；真 SD 需 ENABLE_LOCAL_SD=1 + requirements-media.txt
ENABLE_IMAGE_PLACEHOLDER=1
# ENABLE_LOCAL_SD=1
# SD_MODEL_ID=runwayml/stable-diffusion-v1-5

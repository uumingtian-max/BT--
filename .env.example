# ===== BT黑光 配置示例 =====

# 入口域名
APP_DOMAIN=aquan.love

# 主脑（云端 Claude）
LLM_BACKEND=openai_compatible
OPENAI_BASE_URL=https://inferaichat.com/v1
AGENT_DEFAULT_MODEL=claude-opus-4-7

# 本地GPU模型（sglang :30000）
SGLANG_BASE_URL=http://127.0.0.1:30000/v1
LOCAL_GPU_MODEL=nemotron-omni

# NPU记忆嵌入（sglang :30001）
EMBED_BACKEND=sglang
EMBED_BASE_URL=http://127.0.0.1:30001/v1
EMBED_MODEL=nemotron-embed-1b-v2

# 后端端口
BACKEND_PORT=8000

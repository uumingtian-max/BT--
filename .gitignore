# ── 数据库（运行时生成，不入版本管理）──────────────────────────────────────────
*.db
*.db-shm
*.db-wal
*.db-journal

# ── 环境变量（含真实配置，绝对不提交）──────────────────────────────────────────
.env
backend/.env
backend/.env.bak-*
# .env.example 和 .env.*.example 是模板，可以提交
!.env.example
!backend/.env.example
!backend/.env.*.example

# ── 日志 ────────────────────────────────────────────────────────────────────────
logs/
*.log
*.pid

# ── 测试 / 工具输出 ──────────────────────────────────────────────────────────────
outputs/
tmp/pytest-cache/
tmp/pytest-tmp/
tmp/
CLINE_MEMORY.md
backend/.skill_embedding_index.json
backend/.memory_vector_index.json
backend/agent_skills/learned_habit_auto.md
backend/agent_skills/generated/
backend/*.bak
backend/agent.py.bak
# 保留 outputs 目录结构，忽略文件内容
!outputs/.gitkeep

# ── ML 模型二进制 ────────────────────────────────────────────────────────────────
*.pt
*.pth
*.onnx
*.pkl
*.bin
imported-assets/model_v6/
imported-assets/
knowledge-vault/
data/imported-assets/
data/knowledge-vault/
data/*.db
_upgrade_staging/
archive/_upgrade_staging/
# 整包历史快照仅保留在本机，勿提交（体积大、含旧 .env 备份）
archive/_onyx_pack_desktop/
archive/_onyx_pack_v1.1.0/

# ── Python ───────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
env/
*.egg-info/
dist/
build/

# ── Node / React ─────────────────────────────────────────────────────────────────
node_modules/
frontend/build/
*.tsbuildinfo

# ── Electron ─────────────────────────────────────────────────────────────────────
electron/dist/
/release/
# GitHub Actions 工作流必须纳入版本管理（勿被 release/ 等规则误伤）
!.github/
!.github/workflows/
!.github/workflows/*.yml

# ── pytest ───────────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/

# ── 编辑器 ───────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
Thumbs.db
.DS_Store

# ── 外仓对照（manifest/README 可提交，克隆内容不入库）────────────────────────────
vendor/*/
!vendor/README.md
!vendor/repos.manifest.json

# ── zip 打包产物（不应进 src/）──────────────────────────────────────────────────
frontend/src/*.zip

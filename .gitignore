# ── 数据库（运行时生成，不入版本管理）──────────────────────────────────────────
*.db
*.db-shm
*.db-wal
*.db-journal

# ── 环境变量（含真实配置，绝对不提交）──────────────────────────────────────────
.env
backend/.env
backend/.env.bak-*
# .env.example 和 .env.*.example 是模板，可以提交
!.env.example
!backend/.env.example
!backend/.env.*.example

# ── 日志 ────────────────────────────────────────────────────────────────────────
logs/
*.log
*.pid

# ── 测试 / 工具输出 ──────────────────────────────────────────────────────────────
outputs/
tmp/pytest-cache/
tmp/pytest-tmp/
tmp/
CLINE_MEMORY.md
backend/.skill_embedding_index.json
# 保留 outputs 目录结构，忽略文件内容
!outputs/.gitkeep

# ── ML 模型二进制 ────────────────────────────────────────────────────────────────
*.pt
*.pth
*.onnx
*.pkl
*.bin
imported-assets/model_v6/
imported-assets/
knowledge-vault/
_upgrade_staging/

# ── Python ───────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
env/
*.egg-info/
dist/
build/

# ── Node / React ─────────────────────────────────────────────────────────────────
node_modules/
frontend/build/
*.tsbuildinfo

# ── Electron ─────────────────────────────────────────────────────────────────────
electron/dist/
release/

# ── pytest ───────────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/

# ── 编辑器 ───────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
Thumbs.db
.DS_Store

# ── zip 打包产物（不应进 src/）──────────────────────────────────────────────────
frontend/src/*.zip

entrypoint = "start.py"
modules = ["python-3.11", "nodejs-20"]
hidden = [".pythonlibs", "node_modules", "frontend/node_modules", "frontend/build", "logs", "outputs", "*.db"]

# Replit only runs the web/backend preview. The Electron desktop shell and local vLLM/Ollama model stay on the user's Windows machine.
run = "bash scripts/replit-run.sh"

[nix]
channel = "stable-24_05"

[gitHubImport]
requiredFiles = [".replit", "replit.nix", "scripts/replit-run.sh"]

[[ports]]
localPort = 8000
externalPort = 80

[deployment]
build = "npm install && npm install --prefix frontend && npm run build --prefix frontend && python -m pip install -r requirements.txt"
run = ["bash", "scripts/replit-run.sh"]
deploymentTarget = "cloudrun"
